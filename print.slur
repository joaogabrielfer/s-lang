;; "10 % 30 %" 20 40 ;;
fun print {
	push "%"			        ;; -> "%", "10 % 30 %", 20, 40 ;;
	splitb    			        ;; -> "10", "30 %", 20, 40     ;;
	if {
		pop                     ;; -> "30 %", 20, 40           ;;
		swap                    ;; -> 20, "30 %", 40           ;;
		pop                     ;; -> "30 %", 40               ;;
		call print
	} else {
		push "\n"
		pop
		pop
	}
}

push 40
push 20
push "10 % 30 %"
call print
