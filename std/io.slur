fun printf {
	push "%"
	splitb
	if {
		pop
		swap
		pop
		call printf
	} else {
		push "\n"
		pop
		pop
	}
}

fun print {
	pop
	push "\n"
	pop
}

fun readfile {
	into var path
	push 0
	call __readfile
}

fun __readfile {
	push 1
	add
	dup path
	over
	readlineb
	not if {
		drop
		ret
	}
	swap
	call __readfile
}

